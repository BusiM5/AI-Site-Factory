# Single-administrator login. Generate the hash with:
# python scripts/hash_admin_password.py
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=pbkdf2_sha256$600000$replace_with_generated_salt$replace_with_generated_hash
# Use a separate random value of at least 32 characters.
ADMIN_SESSION_SECRET=replace_with_a_long_random_session_secret
ADMIN_SESSION_MAX_AGE_SECONDS=28800

# Existing integration variables stay server-side. Never prefix these with VITE_.
APIFY_API_TOKEN=
GEMINI_API_KEY=
GROQ_API_KEY=
GITHUB_OWNER=
GITHUB_TOKEN=
NETLIFY_AUTH_TOKEN=
ZENDESK_SUBDOMAIN=
ZENDESK_EMAIL=
ZENDESK_API_TOKEN=
ZENDESK_WEBHOOK_SECRET=
